{
  "name": "@cortexkit/opencode-anthropic-auth",
  "version": "1.1.3",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cortexkit/anthropic-auth.git",
    "directory": "packages/opencode"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "opencode-anthropic-auth": "dist/cli.js"
  },
  "engines": {
    "bun": "1.3.11"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "dev": "bun ../../scripts/dev.ts",
    "dev:clean": "bun ../../scripts/dev-clean.ts",
    "extract": "bun ../../scripts/extract-system-prompt.ts",
    "test": "bun test src/tests",
    "typecheck": "tsc",
    "types": "tsc",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "*"
  },
  "dependencies": {
    "@cortexkit/anthropic-auth-core": "1.1.3"
  }
}
