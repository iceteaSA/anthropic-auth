{
  "name": "@cortexkit/opencode-anthropic-auth",
  "version": "1.10.3",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cortexkit/anthropic-auth.git",
    "directory": "packages/opencode"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tui": {
      "types": "./dist/tui.d.ts",
      "import": "./src/tui.tsx"
    },
    "./tui-prefs": {
      "types": "./dist/tui-preferences.d.ts",
      "import": "./dist/tui-preferences.js"
    }
  },
  "oc-plugin": [
    "server",
    "tui"
  ],
  "bin": {
    "opencode-anthropic-auth": "dist/cli.js"
  },
  "engines": {
    "bun": "1.3.14"
  },
  "files": [
    "dist",
    "src/tui.tsx",
    "src/tui/command-dialogs.tsx",
    "src/sidebar-state.ts",
    "src/tui-preferences.ts",
    "src/rpc",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && bun build src/index.ts src/cli.ts src/sidebar-state.ts src/tui-preferences.ts src/rpc/rpc-client.ts src/rpc/port-file.ts src/rpc/protocol.ts src/rpc/rpc-dir.ts --outdir dist --target node --format esm --splitting --external @opencode-ai/plugin --minify && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "build:dev": "rm -rf dist && tsc -p tsconfig.build.json",
    "dev": "bun ../../scripts/dev.ts",
    "dev:clean": "bun ../../scripts/dev-clean.ts",
    "extract": "bun ../../scripts/extract-system-prompt.ts",
    "test": "bun test src/tests",
    "typecheck": "tsc",
    "types": "tsc",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "*"
  },
  "dependencies": {
    "@cortexkit/anthropic-auth-core": "1.10.3",
    "@opentui/core": ">=0.4.2",
    "@opentui/solid": ">=0.4.2",
    "jsonc-parser": "^3.3.1",
    "solid-js": "^1.9.10"
  }
}
